<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ur5_gripper">

  <xacro:arg name="ur_type" default="ur5"/>
  <!-- sim_gazebo=false so UR macro does NOT create its own ros2_control or gazebo plugin -->
  <xacro:arg name="sim_gazebo" default="false"/>

  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>

  <xacro:arg name="controllers_yaml" default=""/>
  
  <link name="world"/>

  <xacro:ur_robot
    name="ur5"
    tf_prefix=""
    parent="world"
    joint_limits_parameters_file="$(find ur_description)/config/$(arg ur_type)/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/$(arg ur_type)/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/$(arg ur_type)/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/$(arg ur_type)/visual_parameters.yaml"
    sim_gazebo="$(arg sim_gazebo)">
    <origin xyz="-0.05 0.0 0.70" rpy="0 0 0"/>
  </xacro:ur_robot>

  <!-- Mesh paths -->
  <xacro:property name="mesh_dir" value="package://dynamic_reorient/meshes/robotiq"/>

  <!-- ROBOTIQ 2F-85 GRIPPER                       -->

  <link name="gripper_base_link">
    <visual>
      <geometry><mesh filename="${mesh_dir}/robotiq_85_base_link_fine.STL"/></geometry>
      <material name="gripper_grey"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/robotiq_85_base_link_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.03"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="tool0"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_outer_knuckle">
    <visual>
      <geometry><mesh filename="${mesh_dir}/outer_knuckle_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/outer_knuckle_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="left_outer_knuckle"/>
    <origin xyz="0 -0.0306011 0.054904" rpy="0 0 3.14159265"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.8" effort="20" velocity="0.5"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <link name="left_outer_finger">
    <visual>
      <geometry><mesh filename="${mesh_dir}/outer_finger_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/outer_finger_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="left_outer_finger_joint" type="fixed">
    <parent link="left_outer_knuckle"/>
    <child link="left_outer_finger"/>
    <origin xyz="0 0.0315 -0.0041" rpy="0 0 0"/>
  </joint>

  <!-- LEFT INNER KNUCKLE -->
  <link name="left_inner_knuckle">
    <visual>
      <geometry><mesh filename="${mesh_dir}/inner_knuckle_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/inner_knuckle_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="left_inner_knuckle_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="left_inner_knuckle"/>
    <origin xyz="0 -0.0127 0.06142" rpy="0 0 3.14159265"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.8" effort="20" velocity="0.5"/>
    <mimic joint="finger_joint" multiplier="1.0" offset="0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- LEFT INNER FINGER -->
  <link name="left_inner_finger">
    <visual>
      <geometry><mesh filename="${mesh_dir}/inner_finger_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/inner_finger_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="left_inner_finger_joint" type="revolute">
    <parent link="left_outer_finger"/>
    <child link="left_inner_finger"/>
    <origin xyz="0 0.0061 0.0471" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="20" velocity="0.5"/>
    <mimic joint="finger_joint" multiplier="-1.0" offset="0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- RIGHT OUTER KNUCKLE -->
  <link name="right_outer_knuckle">
    <visual>
      <geometry><mesh filename="${mesh_dir}/outer_knuckle_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/outer_knuckle_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_outer_knuckle_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="right_outer_knuckle"/>
    <origin xyz="0 0.0306011 0.054904" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.8" effort="20" velocity="0.5"/>
    <mimic joint="finger_joint" multiplier="1.0" offset="0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- RIGHT OUTER FINGER -->
  <link name="right_outer_finger">
    <visual>
      <geometry><mesh filename="${mesh_dir}/outer_finger_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/outer_finger_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_outer_finger_joint" type="fixed">
    <parent link="right_outer_knuckle"/>
    <child link="right_outer_finger"/>
    <origin xyz="0 0.0315 -0.0041" rpy="0 0 0"/>
  </joint>

  <!-- RIGHT INNER KNUCKLE -->
  <link name="right_inner_knuckle">
    <visual>
      <geometry><mesh filename="${mesh_dir}/inner_knuckle_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/inner_knuckle_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_inner_knuckle_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="right_inner_knuckle"/>
    <origin xyz="0 0.0127 0.06142" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.8" effort="20" velocity="0.5"/>
    <mimic joint="finger_joint" multiplier="1.0" offset="0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- RIGHT INNER FINGER -->
  <link name="right_inner_finger">
    <visual>
      <geometry><mesh filename="${mesh_dir}/inner_finger_fine.STL"/></geometry>
      <material name="gripper_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="${mesh_dir}/inner_finger_coarse.STL"/></geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_inner_finger_joint" type="revolute">
    <parent link="right_outer_finger"/>
    <child link="right_inner_finger"/>
    <origin xyz="0 0.0061 0.0471" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="20" velocity="0.5"/>
    <mimic joint="finger_joint" multiplier="-1.0" offset="0"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- TCP -->
  <link name="tcp"/>
  <joint name="tcp_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="tcp"/>
    <origin xyz="0 0 0.14" rpy="0 0 0"/>
  </joint>

  <link name="camera_support">
    <visual>
      <geometry><cylinder radius="0.008" length="0.25"/></geometry>
      <material name="pole_grey"><color rgba="0.35 0.35 0.35 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.008" length="0.20"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_support_joint" type="fixed">
    <parent link="world"/>
    <child link="camera_support"/>
    <origin xyz="0.45 0 1.80" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.05 0.035 0.035"/></geometry>
      <material name="cam_body"><color rgba="0.08 0.08 0.08 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 -0.020"/>
      <geometry><cylinder radius="0.012" length="0.006"/></geometry>
      <material name="cam_lens"><color rgba="0.15 0.15 0.20 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.05 0.035 0.035"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_support"/>
    <child link="camera_link"/>
    <origin xyz="0 0 -0.12" rpy="0 1.5708 0"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="shoulder_pan_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder_lift_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-1.5708</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">1.5708</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_1_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-1.5708</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_2_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-1.5708</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_3_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="finger_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_outer_knuckle_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_inner_knuckle_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_inner_knuckle_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_inner_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_inner_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <xacro:property name="dyn_share" value="$(find-pkg-share dynamic_reorient)"/>
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(arg controllers_yaml)</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="rgbd_camera" type="depth">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.1</near><far>5.0</far></clip>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <camera_name>camera</camera_name>
        <frame_name>camera_optical_frame</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>5.0</max_depth>
      </plugin>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="left_inner_finger">
    <mu1>6</mu1><mu2>6</mu2>
    <kp>60000</kp><kd>20</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="right_inner_finger">
    <mu1>6</mu1><mu2>6</mu2>
    <kp>60000</kp><kd>20</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="left_inner_knuckle">
    <mu1>4</mu1><mu2>4</mu2>
    <kp>40000</kp><kd>15</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="right_inner_knuckle">
    <mu1>4</mu1><mu2>4</mu2>
    <kp>40000</kp><kd>15</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0.1</maxVel>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="gripper_base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="left_outer_knuckle"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="left_outer_finger"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="right_outer_knuckle"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="right_outer_finger"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="camera_support"><material>Gazebo/DarkGrey</material></gazebo>

</robot>
